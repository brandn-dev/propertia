generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  METER_READER
}

enum PropertyOwnershipType {
  OWNED
  LEASED
}

enum PropertyCategory {
  BUILDING
  UNIT
  LAND
  COMMERCIAL_SPACE
  OTHER
}

enum PropertyStatus {
  ACTIVE
  INACTIVE
  UNDER_MAINTENANCE
  ARCHIVED
}

enum TenantType {
  INDIVIDUAL
  BUSINESS
}

enum ContractStatus {
  DRAFT
  ACTIVE
  ENDED
  TERMINATED
  EXPIRED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  OVERDUE
  VOID
}

enum PaymentStatus {
  PENDING
  SETTLED
  FAILED
  REVERSED
}

enum InvoiceItemType {
  RENT
  RECURRING_CHARGE
  UTILITY_READING
  ADJUSTMENT
  ARREARS
}

enum RecurringChargeType {
  INTERNET
  PARKING
  ASSOCIATION_DUES
  MAINTENANCE
  OTHER
}

enum UtilityType {
  ELECTRICITY
  WATER
  GAS
  SEWER
  OTHER
}

enum AllocationType {
  PERCENTAGE
  EQUAL_SPLIT
  BY_AREA
  CUSTOM
}

enum IncreaseType {
  FIXED
  PERCENTAGE
}

enum RentCalculationType {
  SIMPLE
  COMPOUND
}

enum RentBasedOn {
  BASE_RENT
  PREVIOUS_RENT
}

model User {
  id            String         @id @default(cuid())
  username      String         @unique
  displayName   String
  passwordHash  String
  passwordSalt  String
  role          UserRole
  isActive      Boolean        @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  meterReadings MeterReading[]
}

model Property {
  id                   String                @id @default(cuid())
  name                 String
  propertyCode         String                @unique
  ownershipType        PropertyOwnershipType
  category             PropertyCategory
  location             String
  size                 Decimal?              @db.Decimal(12, 2)
  isLeasable           Boolean               @default(false)
  parentPropertyId     String?
  status               PropertyStatus        @default(ACTIVE)
  description          String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  parent               Property?             @relation("PropertyHierarchy", fields: [parentPropertyId], references: [id])
  children             Property[]            @relation("PropertyHierarchy")
  leases               Lease[]
  contracts            Contract[]
  utilityMeters        UtilityMeter[]
  cosas                COSA[]
  cosaAllocations      COSAAllocation[]
  deductions           Deduction[]
  deductionAllocations DeductionAllocation[]

  @@index([parentPropertyId])
  @@index([status])
}

model Lease {
  id              String   @id @default(cuid())
  propertyId      String
  lessorName      String
  startDate       DateTime
  endDate         DateTime
  monthlyRent     Decimal  @db.Decimal(12, 2)
  contractFileUrl String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  property        Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

model Tenant {
  id              String                 @id @default(cuid())
  type            TenantType
  firstName       String?
  lastName        String?
  businessName    String
  contactNumber   String?
  email           String?
  address         String?
  validIdType     String?
  validIdNumber   String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  contracts       Contract[]
  invoices        Invoice[]
  utilityMeters   UtilityMeter[]
  meterReadings   MeterReading[]
  representatives TenantRepresentative[]
}

model TenantRepresentative {
  id            String   @id @default(cuid())
  tenantId      String
  firstName     String
  lastName      String
  positionTitle String?
  contactNumber String?
  email         String?
  isPrimary     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Contract {
  id               String           @id @default(cuid())
  propertyId       String
  tenantId         String
  startDate        DateTime
  endDate          DateTime
  monthlyRent      Decimal          @db.Decimal(12, 2)
  advanceRent      Decimal          @default(0) @db.Decimal(12, 2)
  securityDeposit  Decimal          @default(0) @db.Decimal(12, 2)
  paymentStartDate DateTime
  status           ContractStatus   @default(DRAFT)
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  property         Property         @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  rentAdjustments  RentAdjustment[]
  recurringCharges ContractRecurringCharge[]
  invoices         Invoice[]
  payments         Payment[]

  @@index([propertyId])
  @@index([tenantId])
  @@index([status])
}

model ContractRecurringCharge {
  id                 String              @id @default(cuid())
  contractId         String
  chargeType         RecurringChargeType
  label              String
  amount             Decimal             @db.Decimal(12, 2)
  effectiveStartDate DateTime
  effectiveEndDate   DateTime?
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  contract           Contract            @relation(fields: [contractId], references: [id], onDelete: Cascade)
  invoiceItems       InvoiceItem[]

  @@index([contractId, isActive])
  @@index([effectiveStartDate, effectiveEndDate])
}

model RentAdjustment {
  id              String              @id @default(cuid())
  contractId      String
  effectiveDate   DateTime
  increaseType    IncreaseType
  increaseValue   Decimal             @db.Decimal(12, 2)
  calculationType RentCalculationType
  basedOn         RentBasedOn
  notes           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  contract        Contract            @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId, effectiveDate])
}

model Invoice {
  id                 String        @id @default(cuid())
  invoiceNumber      String        @unique
  contractId         String
  tenantId           String
  issueDate          DateTime
  dueDate            DateTime
  billingPeriodStart DateTime
  billingPeriodEnd   DateTime
  subtotal           Decimal       @default(0) @db.Decimal(12, 2)
  additionalCharges  Decimal       @default(0) @db.Decimal(12, 2)
  discount           Decimal       @default(0) @db.Decimal(12, 2)
  totalAmount        Decimal       @default(0) @db.Decimal(12, 2)
  balanceDue         Decimal       @default(0) @db.Decimal(12, 2)
  status             InvoiceStatus @default(DRAFT)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  contract           Contract      @relation(fields: [contractId], references: [id], onDelete: Restrict)
  tenant             Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  items              InvoiceItem[]
  payments           Payment[]

  @@unique([contractId, billingPeriodStart, billingPeriodEnd])
  @@index([contractId])
  @@index([tenantId])
  @@index([status, dueDate])
}

model InvoiceItem {
  id                      String                  @id @default(cuid())
  invoiceId               String
  itemType                InvoiceItemType        @default(RENT)
  description             String
  quantity                Decimal                 @default(1) @db.Decimal(12, 2)
  unitPrice               Decimal                 @default(0) @db.Decimal(12, 2)
  amount                  Decimal                 @default(0) @db.Decimal(12, 2)
  contractRecurringChargeId String?
  meterReadingId          String?                 @unique
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  invoice                 Invoice                 @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  contractRecurringCharge ContractRecurringCharge? @relation(fields: [contractRecurringChargeId], references: [id], onDelete: SetNull)
  meterReading            MeterReading?           @relation(fields: [meterReadingId], references: [id], onDelete: SetNull)
  allocations             PaymentAllocation[]

  @@index([invoiceId])
  @@index([contractRecurringChargeId])
}

model Payment {
  id              String        @id @default(cuid())
  invoiceId       String
  contractId      String
  amountPaid      Decimal       @default(0) @db.Decimal(12, 2)
  dueDate         DateTime
  paymentDate     DateTime?
  status          PaymentStatus @default(PENDING)
  referenceNumber String?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  invoice         Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  contract        Contract      @relation(fields: [contractId], references: [id], onDelete: Restrict)
  allocations     PaymentAllocation[]

  @@index([invoiceId])
  @@index([contractId])
  @@index([status])
}

model PaymentAllocation {
  id              String      @id @default(cuid())
  paymentId       String
  invoiceItemId   String
  amountAllocated Decimal     @db.Decimal(12, 2)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  payment         Payment     @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoiceItem     InvoiceItem @relation(fields: [invoiceItemId], references: [id], onDelete: Restrict)

  @@unique([paymentId, invoiceItemId])
  @@index([invoiceItemId])
}

model UtilityMeter {
  id          String         @id @default(cuid())
  propertyId  String
  tenantId    String?
  utilityType UtilityType
  meterCode   String         @unique
  isShared    Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  property    Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant      Tenant?        @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  readings    MeterReading[]
  cosas       COSA[]

  @@index([propertyId])
  @@index([tenantId])
}

model MeterReading {
  id              String       @id @default(cuid())
  meterId         String
  tenantId        String?
  readingDate     DateTime
  previousReading Decimal      @db.Decimal(12, 2)
  currentReading  Decimal      @db.Decimal(12, 2)
  consumption     Decimal      @db.Decimal(12, 2)
  ratePerUnit     Decimal      @db.Decimal(12, 2)
  totalAmount     Decimal      @db.Decimal(12, 2)
  recordedById    String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  meter           UtilityMeter @relation(fields: [meterId], references: [id], onDelete: Cascade)
  tenant          Tenant?      @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  recordedBy      User?        @relation(fields: [recordedById], references: [id], onDelete: SetNull)
  invoiceItem     InvoiceItem?

  @@unique([meterId, readingDate])
  @@index([readingDate])
  @@index([tenantId])
}

model COSA {
  id             String           @id @default(cuid())
  propertyId     String
  meterId        String?
  allocationType AllocationType
  totalAmount    Decimal          @db.Decimal(12, 2)
  billingDate    DateTime
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  property       Property         @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  meter          UtilityMeter?    @relation(fields: [meterId], references: [id], onDelete: SetNull)
  allocations    COSAAllocation[]

  @@index([propertyId, billingDate])
}

model COSAAllocation {
  id             String   @id @default(cuid())
  cosaId         String
  propertyId     String
  percentage     Decimal  @db.Decimal(5, 2)
  computedAmount Decimal  @db.Decimal(12, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  cosa           COSA     @relation(fields: [cosaId], references: [id], onDelete: Cascade)
  property       Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([cosaId, propertyId])
  @@index([propertyId])
}

model Deduction {
  id             String                @id @default(cuid())
  propertyId     String
  description    String
  totalAmount    Decimal               @db.Decimal(12, 2)
  billingDate    DateTime
  allocationType AllocationType
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  property       Property              @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  allocations    DeductionAllocation[]

  @@index([propertyId, billingDate])
}

model DeductionAllocation {
  id             String    @id @default(cuid())
  deductionId    String
  propertyId     String
  percentage     Decimal   @db.Decimal(5, 2)
  computedAmount Decimal   @db.Decimal(12, 2)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deduction      Deduction @relation(fields: [deductionId], references: [id], onDelete: Cascade)
  property       Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([deductionId, propertyId])
  @@index([propertyId])
}
